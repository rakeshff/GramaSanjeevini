<?xml version="1.0" encoding="utf-8"?>
<!--
    GramaSanjeevini Launcher Icon Foreground
    Design: Medical cross (red) + heartbeat/pulse line (white) + small leaf/village dot
    Canvas: 108x108dp  (safe zone: 72x72dp centered at 54,54)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── White rounded square card (safe zone) ─────────────────────────── -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M36,36 Q36,30 42,30 L66,30 Q72,30 72,36 L72,72 Q72,78 66,78 L42,78 Q36,78 36,72 Z" />

    <!-- ── Red medical cross ──────────────────────────────────────────────── -->
    <!-- Vertical bar of cross -->
    <path
        android:fillColor="#EF4444"
        android:pathData="M49,36 L59,36 L59,72 L49,72 Z" />
    <!-- Horizontal bar of cross -->
    <path
        android:fillColor="#EF4444"
        android:pathData="M36,49 L72,49 L72,59 L36,59 Z" />

    <!-- ── White heartbeat / pulse line over the cross ────────────────────── -->
    <!-- This draws a simple ECG-style pulse: flat → spike up → spike down → flat -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M36,54 L43,54 L46,47 L50,61 L54,47 L57,54 L72,54" />

    <!-- ── Small green leaf dot (village / rural symbol) ─────────────────── -->
    <path
        android:fillColor="#22C55E"
        android:pathData="M54,74 Q54,74 50,70 Q47,66 50,63 Q53,60 54,63 Q55,60 58,63 Q61,66 58,70 Q54,74 54,74 Z" />

</vector>
